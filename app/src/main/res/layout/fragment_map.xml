<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/tvMapTotalCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="12dp"
        android:background="#CC0B0F14"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:textColor="#FFB238"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:id="@+id/tvEmptyMap"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Belum ada lubang jalan yang tersimpan.\nMulai scan untuk menambahkan titik ke peta."
        android:textAlignment="center"
        android:textColor="#7C8898"
        android:textSize="14sp"
        android:padding="24dp"
        android:background="#F5F6F8"
        android:visibility="gone" />

</FrameLayout>